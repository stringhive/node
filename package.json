{
  "name": "stringhive",
  "version": "1.0.2",
  "description": "Stringhive CLI and Node.js client for pushing and pulling translation strings",
  "keywords": [
    "stringhive",
    "i18n",
    "l10n",
    "translations",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stringhive/node.git"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "stringhive": "./dist/bin/stringhive.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "STRINGHIVE_INTEGRATION=1 vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src bin --ext .ts",
    "prepublishOnly": "npm run build && npm run typecheck",
    "release-patch": "npm version patch && git push --follow-tags"
  },
  "dependencies": {
    "c12": "^2.0.4",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
